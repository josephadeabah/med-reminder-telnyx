# ============================================================
# Medication Reminder Call API — Backend Configuration
# Copy this file to `.env` and fill in real values.
# ============================================================

# --- App ---
APP_ENV=development            # development | production
LOG_LEVEL=INFO
ALLOWED_ORIGINS=http://localhost:3000

# --- Database ---
# Option A (default for `docker compose up`): the bundled Postgres container.
#   DATABASE_URL=postgresql://postgres:postgres@postgres:5432/med_reminder
# Option B: Supabase — Project Settings -> Database -> Connection string (URI).
#   DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@YOUR_PROJECT.supabase.co:5432/postgres
# Either postgres:// or postgresql:// works - auto-converted to the asyncpg driver at runtime.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/med_reminder

# --- Telnyx ---
TELNYX_API_KEY=KEY0123456789ABCDEF_your_api_key
TELNYX_CONNECTION_ID=1234567890123456789
TELNYX_PUBLIC_KEY=your_base64_ed25519_public_key
TELNYX_PHONE_NUMBER=+15555550123

# --- Public webhook base URL ---
# For local/demo use ngrok: `ngrok http 8000`, then paste the https URL here (no trailing slash).
PUBLIC_BASE_URL=https://your-ngrok-subdomain.ngrok-free.app

# --- Security ---
VALIDATE_TELNYX_SIGNATURE=true
DEMO_ADMIN_TOKEN=

# --- Scheduler (system-to-patient calls at scheduled dose times) ---
SCHEDULER_ENABLED=true
DOSE_DISPATCH_INTERVAL_SECONDS=30
DOSE_DUE_GRACE_MINUTES=2

# --- Demo data ---
# When true, `entrypoint.sh` runs `python -m app.seed` after migrations,
# creating one demo caregiver/patient/medications set if none exists yet.
SEED_DEMO_DATA=true
